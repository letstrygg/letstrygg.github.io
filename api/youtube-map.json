---
permalink: /api/youtube-map.json
---
{% assign all_docs = site.pages | concat: site.documents %}
{% assign first_item = true %}
{
{% for doc in all_docs %}
  {% assign yid = nil %}
  
  {% if doc.youtube_id %}
    {% assign yid = doc.youtube_id %}
  {% elsif doc.thumbnail contains 'i.ytimg.com/vi/' %}
    {% assign parts = doc.thumbnail | split: '/vi/' %}
    {% assign yid = parts[1] | split: '/' | first %}
  {% endif %}
  
  {% if yid %}
    {% unless first_item %},{% endunless %}
    "{{ yid }}": "{{ doc.url }}"
    {% assign first_item = false %}
  {% endif %}
{% endfor %}
}