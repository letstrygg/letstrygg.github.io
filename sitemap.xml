---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="{{ '/sitemap.xsl' | relative_url }}"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign sorted_pages = site.pages | sort: "url" %}
  {% for page in sorted_pages %}
    {% assign last_char = page.url | slice: -1 %}
    {% if page.url contains '.html' or last_char == '/' %}
      {% unless page.url contains '404' or page.sitemap == false %}
      <url>
        <loc>{{ page.url | absolute_url }}</loc>
        <lastmod>
        {%- if page.last_modified_at -%}
          {{ page.last_modified_at | date_to_xmlschema }}
        {%- elsif page.date -%}
          {{ page.date | date_to_xmlschema }}
        {%- else -%}
          {{ site.time | date_to_xmlschema }}
        {%- endif -%}
        </lastmod>
      </url>
      {% endunless %}
    {% endif %}
  {% endfor %}
</urlset>